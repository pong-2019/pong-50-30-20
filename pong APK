<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>การทำตามสัดส่วนการเงิน 50/30/20</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Sarabun', Tahoma, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            color: #333;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.2rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .header p {
            opacity: 0.9;
            margin-top: 8px;
            font-size: 1.1rem;
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 24px 28px;
            margin-bottom: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15);
            transition: transform 0.2s ease;
        }

        .card:hover {
            transform: translateY(-2px);
        }

        .card h2 {
            font-size: 1.3rem;
            margin-bottom: 18px;
            color: #444;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card h2 .icon {
            font-size: 1.5rem;
        }

        .input-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }

        .input-group label {
            font-weight: 600;
            color: #555;
            font-size: 1.05rem;
        }

        .input-group input {
            flex: 1;
            min-width: 180px;
            padding: 12px 16px;
            font-size: 1.1rem;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            outline: none;
            transition: border-color 0.3s ease;
        }

        .input-group input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
        }

        .btn {
            padding: 12px 28px;
            font-size: 1.05rem;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102,126,234,0.4);
        }

        .btn-danger {
            background: #ff4757;
            color: white;
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(255,71,87,0.4);
        }

        .btn-secondary {
            background: #f0f0f0;
            color: #555;
        }

        .btn-secondary:hover {
            background: #e0e0e0;
        }

        .result-box {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-top: 20px;
        }

        .result-item {
            padding: 18px;
            border-radius: 12px;
            text-align: center;
            color: white;
        }

        .result-item.spending {
            background: linear-gradient(135deg, #ff6b6b, #ee5a24);
        }

        .result-item.savings {
            background: linear-gradient(135deg, #2ed573, #7bed9f);
            color: #333;
        }

        .result-item.reserve {
            background: linear-gradient(135deg, #1e90ff, #3742fa);
        }

        .result-item.total {
            background: linear-gradient(135deg, #ffa502, #ff6348);
        }

        .result-item .label {
            font-size: 0.95rem;
            opacity: 0.9;
        }

        .result-item .amount {
            font-size: 1.8rem;
            font-weight: 700;
            margin-top: 6px;
        }

        .result-item .percent {
            font-size: 0.9rem;
            opacity: 0.8;
            margin-top: 4px;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 700px) {
            .summary-grid {
                grid-template-columns: 1fr;
            }
        }

        .summary-table {
            width: 100%;
            border-collapse: collapse;
        }

        .summary-table th,
        .summary-table td {
            padding: 10px 14px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        .summary-table th {
            font-weight: 600;
            color: #888;
            font-size: 0.85rem;
            text-transform: uppercase;
        }

        .summary-table td {
            font-size: 1rem;
        }

        .summary-table .total-row {
            font-weight: 700;
            font-size: 1.1rem;
            border-top: 2px solid #ddd;
        }

        .summary-table .total-row td {
            border-bottom: none;
        }

        .chart-container {
            position: relative;
            height: 250px;
            width: 100%;
        }

        .history-list {
            max-height: 300px;
            overflow-y: auto;
        }

        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        .history-item:last-child {
            border-bottom: none;
        }

        .history-item .date {
            color: #999;
            font-size: 0.85rem;
        }

        .history-item .cat-spending { color: #ee5a24; }
        .history-item .cat-savings { color: #2ed573; }
        .history-item .cat-reserve { color: #3742fa; }

        .history-item .amount {
            font-weight: 600;
        }

        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 16px 24px;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
            transform: translateX(120%);
            transition: transform 0.4s ease;
            z-index: 999;
        }

        .toast.show {
            transform: translateX(0);
        }

        .toast.success {
            background: linear-gradient(135deg, #2ed573, #7bed9f);
            color: #333;
        }

        .toast.error {
            background: linear-gradient(135deg, #ff6b6b, #ee5a24);
        }

        .toast.info {
            background: linear-gradient(135deg, #1e90ff, #3742fa);
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #aaa;
        }

        .empty-state .big-icon {
            font-size: 4rem;
            margin-bottom: 16px;
        }

        .empty-state p {
            font-size: 1.1rem;
        }

        .actions-bar {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: white;
            border-radius: 16px;
            padding: 32px;
            max-width: 400px;
            width: 90%;
            text-align: center;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        .modal h3 {
            margin-bottom: 16px;
            font-size: 1.3rem;
        }

        .modal p {
            color: #666;
            margin-bottom: 24px;
        }

        .modal .btn-group {
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        .footer {
            text-align: center;
            color: rgba(255,255,255,0.6);
            margin-top: 30px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>💰 การทำตามสัดส่วนการเงิน 50/30/20</h1>
            <p>บันทึกทุกครั้งที่มีเงินเข้า ระบบจะคำนวณสัดส่วนให้อัตโนมัติ</p>
        </div>

        <!-- Card: บันทึกรายรับ -->
        <div class="card">
            <h2><span class="icon">📥</span> บันทึกรายรับใหม่</h2>
            <div class="input-group">
                <label>ยอดเงินเข้า (บาท):</label>
                <input type="number" id="incomeInput" placeholder="เช่น 5000" min="0" step="0.01">
                <button class="btn btn-primary" onclick="addIncome()">💾 บันทึก</button>
            </div>
            <div id="resultContainer" style="display:none;">
                <div class="result-box" id="resultBox"></div>
            </div>
        </div>

        <!-- Card: สรุปยอดสะสม + กราฟ -->
        <div class="card">
            <h2><span class="icon">📊</span> สรุปยอดสะสม</h2>
            <div class="summary-grid">
                <div>
                    <table class="summary-table" id="summaryTable">
                        <thead>
                            <tr>
                                <th>หมวด</th>
                                <th style="text-align:right;">ยอดสะสม</th>
                            </tr>
                        </thead>
                        <tbody id="summaryBody">
                            <tr>
                                <td colspan="2">
                                    <div class="empty-state">
                                        <div class="big-icon">📭</div>
                                        <p>ยังไม่มีข้อมูล</p>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div>
                    <div class="chart-container">
                        <canvas id="pieChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="actions-bar" style="margin-top:16px;">
                <button class="btn btn-secondary" onclick="refreshData()">🔄 รีเฟรช</button>
                <button class="btn btn-danger" onclick="showResetModal()">🗑️ ล้างข้อมูล</button>
            </div>
        </div>

        <!-- Card: ประวัติ -->
        <div class="card">
            <h2><span class="icon">📜</span> ประวัติรายการล่าสุด</h2>
            <div class="history-list" id="historyList">
                <div class="empty-state">
                    <div class="big-icon">📭</div>
                    <p>ยังไม่มีประวัติ</p>
                </div>
            </div>
        </div>

        <div class="footer">
            💰 ทำตามสัดส่วน 50/30/20 ทุกครั้งที่มีเงินเข้า • ข้อมูลถูกบันทึกในเครื่องของคุณ
        </div>
    </div>

    <!-- Modal ยืนยันล้างข้อมูล -->
    <div class="modal-overlay" id="resetModal">
        <div class="modal">
            <h3>⚠️ ยืนยันการล้างข้อมูล</h3>
            <p>คุณต้องการล้างข้อมูลทั้งหมดใช่หรือไม่?<br>การกระทำนี้ไม่สามารถย้อนกลับได้</p>
            <div class="btn-group">
                <button class="btn btn-secondary" onclick="closeResetModal()">ยกเลิก</button>
                <button class="btn btn-danger" onclick="resetData()">ยืนยัน ล้างข้อมูล</button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="toast" id="toast"></div>

    <script>
        // ====== Data Management ======
        const STORAGE_KEY = 'finance_50_30_20_data';

        function getData() {
            const raw = localStorage.getItem(STORAGE_KEY);
            return raw ? JSON.parse(raw) : [];
        }

        function saveData(data) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        }

        function formatNumber(num) {
            return num.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function getNow() {
            const d = new Date();
            const pad = (n) => String(n).padStart(2, '0');
            return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        }

        // ====== Toast ======
        let toastTimer = null;

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = `toast ${type}`;
            // Force reflow
            void toast.offsetWidth;
            toast.classList.add('show');

            if (toastTimer) clearTimeout(toastTimer);
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ====== Modal ======
        function showResetModal() {
            document.getElementById('resetModal').classList.add('active');
        }

        function closeResetModal() {
            document.getElementById('resetModal').classList.remove('active');
        }

        // ====== Main Functions ======
        function addIncome() {
            const input = document.getElementById('incomeInput');
            const amount = parseFloat(input.value);

            if (isNaN(amount) || amount <= 0) {
                showToast('❌ กรุณากรอกยอดเงินที่มากกว่า 0', 'error');
                input.focus();
                return;
            }

            // Calculate 50/30/20
            const spending = amount * 0.50;
            const savings = amount * 0.30;
            const reserve = amount * 0.20;

            const timestamp = getNow();
            const newRecords = [
                { Timestamp: timestamp, Category: 'spending', Amount: spending },
                { Timestamp: timestamp, Category: 'savings', Amount: savings },
                { Timestamp: timestamp, Category: 'reserve', Amount: reserve }
            ];

            // Save
            const data = getData();
            data.push(...newRecords);
            saveData(data);

            // Show result
            const resultContainer = document.getElementById('resultContainer');
            const resultBox = document.getElementById('resultBox');
            resultContainer.style.display = 'block';
            resultBox.innerHTML = `
                <div class="result-item total">
                    <div class="label">💰 รับเงินเข้า</div>
                    <div class="amount">${formatNumber(amount)}</div>
                    <div class="percent">100%</div>
                </div>
                <div class="result-item spending">
                    <div class="label">🛍️ เงินใช้จ่าย</div>
                    <div class="amount">${formatNumber(spending)}</div>
                    <div class="percent">50%</div>
                </div>
                <div class="result-item savings">
                    <div class="label">🏦 เงินเก็บ</div>
                    <div class="amount">${formatNumber(savings)}</div>
                    <div class="percent">30%</div>
                </div>
                <div class="result-item reserve">
                    <div class="label">🛡️ เงินสำรอง</div>
                    <div class="amount">${formatNumber(reserve)}</div>
                    <div class="percent">20%</div>
                </div>
            `;

            // Clear input
            input.value = '';
            input.focus();

            showToast(`✅ บันทึกยอด ${formatNumber(amount)} บาท เรียบร้อย!`, 'success');

            // Refresh summary and history
            updateSummary();
            updateHistory();
            updateChart();
        }

        function updateSummary() {
            const data = getData();
            const tbody = document.getElementById('summaryBody');

            if (data.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="2">
                            <div class="empty-state">
                                <div class="big-icon">📭</div>
                                <p>ยังไม่มีข้อมูล</p>
                            </div>
                        </td>
                    </tr>
                `;
                return;
            }

            // Aggregate
            const totals = { spending: 0, savings: 0, reserve: 0 };
            data.forEach(r => {
                if (totals[r.Category] !== undefined) {
                    totals[r.Category] += r.Amount;
                }
            });
            const grandTotal = totals.spending + totals.savings + totals.reserve;
            const count = data.length / 3;

            const catNames = {
                spending: '🛍️ เงินใช้จ่าย (50%)',
                savings: '🏦 เงินเก็บ (30%)',
                reserve: '🛡️ เงินสำรอง (20%)'
            };
            const catColors = {
                spending: '#ee5a24',
                savings: '#2ed573',
                reserve: '#3742fa'
            };

            let rows = '';
            for (const [key, label] of Object.entries(catNames)) {
                rows += `
                    <tr>
                        <td style="color:${catColors[key]}"><strong>${label}</strong></td>
                        <td style="text-align:right; font-weight:600;">${formatNumber(totals[key])} บาท</td>
                    </tr>
                `;
            }
            rows += `
                <tr class="total-row">
                    <td>📌 รวมทั้งหมด</td>
                    <td style="text-align:right;">${formatNumber(grandTotal)} บาท</td>
                </tr>
                <tr>
                    <td colspan="2" style="text-align:center; color:#999; font-size:0.85rem; padding-top:8px;">
                        ℹ️ จำนวนครั้งที่บันทึก: ${count} ครั้ง
                    </td>
                </tr>
            `;

            tbody.innerHTML = rows;
        }

        function updateHistory() {
            const data = getData();
            const container = document.getElementById('historyList');

            if (data.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="big-icon">📭</div>
                        <p>ยังไม่มีประวัติ</p>
                    </div>
                `;
                return;
            }

            // Sort by timestamp descending, take last 10 entries (30 records)
            const sorted = [...data].sort((a, b) => b.Timestamp.localeCompare(a.Timestamp));
            const latest = sorted.slice(0, 30); // 10 entries × 3 categories

            const catNames = {
                spending: { label: '🛍️ ใช้จ่าย', cls: 'cat-spending' },
                savings: { label: '🏦 เก็บ', cls: 'cat-savings' },
                reserve: { label: '🛡️ สำรอง', cls: 'cat-reserve' }
            };

            // Group by timestamp
            const groups = {};
            latest.forEach(r => {
                if (!groups[r.Timestamp]) {
                    groups[r.Timestamp] = {};
                }
                groups[r.Timestamp][r.Category] = r.Amount;
            });

            let html = '';
            for (const [ts, cats] of Object.entries(groups)) {
                const datePart = ts.substring(0, 10);
                const timePart = ts.substring(11, 19);
                html += `<div class="history-item" style="flex-wrap:wrap;">`;
                html += `<span class="date">${datePart} ${timePart}</span>`;
                for (const [cat, info] of Object.entries(catNames)) {
                    if (cats[cat] !== undefined) {
                        html += `<span class="${info.cls}" style="font-weight:600;">${info.label} ${formatNumber(cats[cat])}</span>`;
                    }
                }
                html += `</div>`;
            }

            container.innerHTML = html;
        }

        let chartInstance = null;

        function updateChart() {
            const data = getData();
            const ctx = document.getElementById('pieChart').getContext('2d');

            if (chartInstance) {
                chartInstance.destroy();
            }

            if (data.length === 0) {
                chartInstance = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['ยังไม่มีข้อมูล'],
                        datasets: [{
                            data: [1],
                            backgroundColor: ['#e0e0e0']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        }
                    }
                });
                return;
            }

            const totals = { spending: 0, savings: 0, reserve: 0 };
            data.forEach(r => {
                if (totals[r.Category] !== undefined) {
                    totals[r.Category] += r.Amount;
                }
            });

            chartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['🛍️ ใช้จ่าย 50%', '🏦 เก็บ 30%', '🛡️ สำรอง 20%'],
                    datasets: [{
                        data: [totals.spending, totals.savings, totals.reserve],
                        backgroundColor: ['#ee5a24', '#2ed573', '#3742fa'],
                        borderWidth: 3,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 16,
                                font: { size: 13 }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const value = context.parsed;
                                    const percent = ((value / total) * 100).toFixed(1);
                                    return `${context.label}: ${formatNumber(value)} บาท (${percent}%)`;
                                }
                            }
                        }
                    }
                }
            });
        }

        function refreshData() {
            updateSummary();
            updateHistory();
            updateChart();
            showToast('🔄 รีเฟรชข้อมูลเรียบร้อย', 'info');
        }

        function resetData() {
            saveData([]);
            closeResetModal();

            // Clear result
            document.getElementById('resultContainer').style.display = 'none';
            document.getElementById('incomeInput').value = '';

            updateSummary();
            updateHistory();
            updateChart();
            showToast('🗑️ ล้างข้อมูลเรียบร้อย', 'info');
        }

        // ====== Enter key support ======
        document.getElementById('incomeInput').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                addIncome();
            }
        });

        // ====== Initialize on load ======
        document.addEventListener('DOMContentLoaded', function() {
            updateSummary();
            updateHistory();
            updateChart();
            document.getElementById('incomeInput').focus();
        });
    </script>
</body>
</html>
